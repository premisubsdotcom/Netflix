<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>Domains</title><link rel="stylesheet" href="/style.css"></head><body><main class="wrap"><section class="card hero"><h1>Domains</h1><p>View mails or delete complete domain collections.</p><div class="nav"><a class="btn" href="/mail">Generate mail</a><a class="btn secondary" href="/url">URL shortener</a></div></section><% if(error){ %><div class="alert error"><%= error %></div><% } %><% if(ok){ %><div class="alert ok"><%= ok %></div><% } %><section class="grid"><% domains.forEach(d => { %><div class="card domain"><h2><%= d.domain %></h2><p class="muted">Collection: <%= d.collection %></p><a class="btn full" target="_blank" href="/mail/domain/<%= d.domain %>.txt">View mails</a><form method="post" action="/mail/delete-domain" onsubmit="return askPassword(this)"><input type="hidden" name="domain" value="<%= d.domain %>"><input type="hidden" name="password"><button class="danger full" type="submit">Delete domain</button></form></div><% }) %><% if(!domains.length){ %><div class="card"><p>No domains added.</p></div><% } %></section></main><script src="/script.js"></script></body></html>
